# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Next Auth Google Provider
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="mysql://root:password@localhost:3306/muheshimiwa-md"

# MoveSMS API for SMS notifications
# Get your API key from https://movesms.io
MOVESMS_API_KEY=""

# Mobitech SMS API (recommended)
# API docs: https://app.mobitechtechnologies.com/sms/sendmultiple
MOBITECH_API_KEY=""
MOBITECH_SHORTCODE="MOBI-TECH"
MOBITECH_SERVICE_ID="0"
# Optional: validate numbers through /sms/mobile before sending
MOBITECH_VALIDATE_NUMBERS="false"
# Optional: secret token to protect your DLR webhook endpoint
MOBITECH_DLR_SECRET=""

# SMTP configuration (Google Workspace/Gmail defaults)
# For Gmail use an App Password, not your normal account password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASSWORD="your-google-app-password"
SMTP_FROM="your-gmail@gmail.com"

# Admin bootstrap credentials (used once to create/verify first admin account)
# Use a unique username and a long random password.
# Example password generation (Linux):
#   openssl rand -base64 48 | tr -d '\n'
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="REPLACE_WITH_A_LONG_RANDOM_PASSWORD"
