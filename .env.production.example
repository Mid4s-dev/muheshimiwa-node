# Production Environment Configuration for Docker Deployment
# Copy this file to .env and fill in your values before deploying

# ============================================================================
# NEXT.JS / AUTHENTICATION
# ============================================================================

# NextAuth secret key (generate with: openssl rand -base64 32)
AUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# Your application URL (MUST be https:// for production)
NEXTAUTH_URL="https://yourdomain.com"

# Public site URL for SEO and social sharing
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ============================================================================
# DATABASE
# ============================================================================

# MySQL credentials (change MYSQL_ROOT_PASSWORD for security)
MYSQL_ROOT_PASSWORD="change-me-to-strong-password"
MYSQL_DATABASE="mejja"
MYSQL_PORT="3306"
MYSQL_USERNAME="root"

# Note: DATABASE_URL is auto-generated in docker-compose.yml
# Format: mysql://root:PASSWORD@mysql:3306/mejja

# ============================================================================
# EMAIL (SMTP)
# ============================================================================

# Gmail SMTP settings
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
# Use a Google App Password (NOT your regular password)
# Create at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD="xxxx xxxx xxxx xxxx"
SMTP_FROM="sender@yourdomain.com"

# Alternative: Use custom SMTP server
# SMTP_HOST="mail.yourdomain.com"
# SMTP_PORT="587"
# SMTP_SECURE="true"
# SMTP_USER="your-email@yourdomain.com"
# SMTP_PASSWORD="your-password"

# ============================================================================
# SMS (MOBITECH API)
# ============================================================================

# Get API key from: https://www.mobitech.co.ke/
MOBITECH_API_KEY="your-api-key-here"
MOBITECH_SHORTCODE="MOBI-TECH"
MOBITECH_SERVICE_ID="0"

# Validate numbers before sending SMS (optional)
MOBITECH_VALIDATE_NUMBERS="false"

# Webhook secret for DLR (delivery receipt) callbacks
MOBITECH_DLR_SECRET="generate-a-random-secret"

# ============================================================================
# GOOGLE OAUTH (Optional - for social login)
# ============================================================================

# Get from: https://console.developers.google.com/
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ============================================================================
# ADMIN CREDENTIALS
# ============================================================================

# These credentials are used to bootstrap the first admin account
# ONLY used on first startup, then can be changed in the app
# Use a strong password!
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-to-very-strong-password"

# ============================================================================
# NODE.JS / DEPLOYMENT
# ============================================================================

NODE_ENV="production"
PORT="3000"

# Disable Next.js telemetry in production
NEXT_TELEMETRY_DISABLED="1"

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================

# BEFORE DEPLOYMENT:
# 1. Generate AUTH_SECRET: openssl rand -base64 32
# 2. Set NEXTAUTH_URL to your production domain with https://
# 3. Get Google OAuth credentials if using social login
# 4. Set SMTP credentials for email functionality
# 5. Get MOBITECH_API_KEY for SMS functionality
# 6. Change database password from default "root"
# 7. Change admin password to something strong

# DOCKER DEPLOYMENT:
# docker-compose up -d

# PLATFORM-SPECIFIC:

# Railway.app:
#   - Connect GitHub repo
#   - Set environment variables in Railway dashboard
#   - MySQL service auto-provisioned

# Render.com:
#   - Create Web Service from Docker
#   - Set environment variables
#   - Choose "Pro" or "Standard" instance type

# DigitalOcean App Platform:
#   - Select Docker from App Spec
#   - Configure MySQL component
#   - Set environment variables

# Self-hosted (VPS):
#   - SSH into server
#   - Clone repo and cd into directory
#   - cp .env.docker .env && nano .env (set variables)
#   - docker-compose up -d
#   - Set up Nginx reverse proxy with HTTPS
#   - Use certbot for Let's Encrypt certificates
